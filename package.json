{
  "name": "blank-project-template",
  "private": true,
  "version": "0.1.0",
  "description": "Local cloneable template to start projects from a Spec Kit.",
  "scripts": {
    "init": "node scripts/init-project.js",
    "bootstrap": "node scripts/bootstrap-project.js",
    "connect_project": "node scripts/connect-project.js",
    "matrix:authorize": "node scripts/authorize-matrix.js",
    "clarify_brief": "node scripts/clarify-brief.js",
    "clarify_spec_kit": "node scripts/clarify-spec-kit.js",
    "clarify_sprints": "node scripts/clarify-sprints.js",
    "clarify_sprint": "node scripts/clarify-sprint.js",
    "update_spec_kit": "node scripts/update-spec-kit.js",
    "update_agency_agents": "node scripts/update-agency-agents.js",
    "generate_skills": "node scripts/generate-skills.js",
    "generate_skills:antigravity": "node scripts/generate-skills.js --tool antigravity",
    "generate_skills:claude": "node scripts/generate-skills.js --tool claude-code",
    "generate_skills:dry": "node scripts/generate-skills.js --dry-run",
    "generate_brief": "node scripts/generate-brief.js",
    "generate_spec_kit": "node scripts/generate-spec-kit.js --mode matrix --brief spec-kit/input/brief.md",
    "generate_sprints": "node scripts/plan-all-sprints.js --mode local",
    "approve_sprints_plan": "node scripts/approve-sprints-plan.js",
    "start_sprint": "node scripts/start-sprint.js",
    "continue_sprint": "node scripts/continue-sprint.js",
    "reset_project": "node scripts/reset-project.js",
    "next_step": "node scripts/next-step.js",
    "brief:validate": "node scripts/validate-briefing.js",
    "status": "node scripts/status-report.js",
    "sync_workflow_status": "node scripts/sync-workflow-status.js",
