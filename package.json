    "sprint:init": "node scripts/generate-sprint-files.js",
    "sprints:plan": "node scripts/plan-all-sprints.js --mode local",
    "spec:generate": "node scripts/generate-spec-kit.js --mode matrix",
    "spec:local": "node scripts/generate-spec-kit.js --mode local",
    "matrix:sync": "node scripts/matrix-sync.js",
    "package:zip": "node scripts/create-project-zip.js",
    "planning:finalize": "node scripts/finalize-planning.js",
    "status:web": "node scripts/status-web-server.js",
    "check:scripts": "node scripts/check-scripts.js",
    "test:local": "node --test tests/status-summary.test.js tests/matrix-client.test.js tests/generate-brief-preconditions.test.js tests/reset-project.test.js tests/clarification.test.js",
    "mcp:matrix": "node mcp/matrix-mcp-server.mjs"
