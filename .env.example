PROJECT_NAME=__PROJECT_NAME__
PROJECT_SLUG=__PROJECT_SLUG__
NODE_ENV=development

# Local AI (developers via IDE command)
LOCAL_AI_PROVIDER=ide_command
LOCAL_IDE_AI_COMMAND=
LOCAL_IDE_AI_TIMEOUT_MS=180000

# Dashboard VISION (status-web); si está ocupado, se usa el siguiente puerto libre
STATUS_WEB_PORT=4173

# Matrix (OpenRouter vive solo en matriz)
MATRIX_BASE_URL=
MATRIX_API_KEY=
MATRIX_REPORT_PATH=/api/vision/local-projects/report
MATRIX_VALIDATE_BRIEF_PATH=/api/vision/briefings/validate
MATRIX_GENERATE_SPEC_PATH=/api/vision/spec-kit/generate
MATRIX_AUTHORIZE_PATH=/api/vision/local-projects/authorize

# Local command to bootstrap Spec Kit when running in local mode
SPEC_KIT_LOCAL_COMMAND=uvx --from git+https://github.com/github/spec-kit.git specify init .
